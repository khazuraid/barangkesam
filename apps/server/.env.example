Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/alkes_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# CORS
# Dapat berupa satu origin, banyak origin (comma-separated), atau pakai wildcard `*` per segmen.
# Contoh untuk dev + scan QR dari HP di LAN WiFi yang sama:
#   CORS_ORIGIN="http://localhost:3000,http://192.168.0.153:3000"
# Atau lebih fleksibel dengan wildcard:
#   CORS_ORIGIN="http://localhost:3000,http://192.168.*.*:3000,http://10.*.*.*:3000"
CORS_ORIGIN="http://localhost:3000,http://192.168.*.*:3000,http://10.*.*.*:3000"
